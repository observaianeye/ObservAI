# ============================================================
#  ObservAI — API Anahtarları Şablonu
#  Bu dosyayı kopyala: cp .env.example .env
#  Sonra .env dosyasını gerçek key'lerle doldur.
# ============================================================

# ── Claude API (Ana AI) ──────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-BURAYA_CLAUDE_API_KEY_YAZ

# ── Ollama (Birincil AI — yerel, ucretsiz) ───────────────────
# https://ollama.ai adresinden indir, sonra: ollama pull llama3.1:8b
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Gemini API (Yedek AI — ucretsiz tier mevcut) ─────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_BURAYA_GEMINI_API_KEY_YAZ

# ── OpenAI API (İkinci Yedek — isteğe bağlı) ─────────────────
# https://platform.openai.com/api-keys
# Boş bırakabilirsin, sistem Claude + Gemini ile çalışır.
OPENAI_API_KEY=

# ── ntfy.sh Bildirimleri ──────────────────────────────────────
# iPhone'unda ntfy uygulamasında hangi topic'i takip ettiğini yaz
# Varsayılan: observai  →  https://ntfy.sh/observai
NTFY_TOPIC=observai

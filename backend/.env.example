# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/observai?schema=public"

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Public URL for outgoing links (password reset emails, etc.)
APP_URL=http://localhost:5173

# AI Configuration
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
# Primary model; start-all.bat falls back to llama3.1:8b if pull fails.
OLLAMA_MODEL=gemma4:26b
# 999 = offload every layer that fits on the GPU (Ollama convention).
# Drop to 0 on CPU-only hosts to avoid CUDA init failures.
OLLAMA_NUM_GPU=999
# Context window. gemma4:26b supports 32k; 4096 keeps prompts fast.
OLLAMA_NUM_CTX=4096
# Request timeout. 26B models need longer first-token latency than smaller models.
OLLAMA_TIMEOUT_MS=180000
# Set to true to enable the /api/ai/chat/stream SSE endpoint + chat history persistence.
ENABLE_AI_STREAMING=false

# Gemini API Configuration (fallback if Ollama unavailable)
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com

# Telegram Bot (bildirimler icin)
# @BotFather'dan /newbot ile olustur, token'i buraya yaz
TELEGRAM_BOT_TOKEN=
# Bot kullanici adi (ornek: ObservAIAlertBot) — QR deep link uretmek icin
TELEGRAM_BOT_USERNAME=
# (Opsiyonel) Production webhook guvenligi icin rastgele secret.
# Set edildiginde Telegram'a setWebhook?secret_token=... ile bildirilmelidir.
TELEGRAM_WEBHOOK_SECRET=

# Email / SMTP (bildirimler icin)
# Gmail: Settings > App Passwords ile olustur
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ObservAI <noreply@observai.com>

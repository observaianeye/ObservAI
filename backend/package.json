{
  "name": "@observai/backend",
  "version": "1.0.0",
  "description": "ObservAI Backend API - Database and REST endpoints",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "npm run start:all",
    "start:node": "cross-env ESBUILD_BINARY_PATH=./node_modules/@esbuild/win32-x64/esbuild.exe tsx watch src/index.ts",
    "start:python": "node scripts/start-python-backend.js",
    "start:all": "concurrently --names \"API,AI\" --prefix-colors \"blue,green\" \"npm run start:node\" \"npm run start:python\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed:history": "tsx scripts/backfill-analytics-summary.ts",
    "reset:today": "tsx scripts/reset-today-analytics.ts",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.17.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.4",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.2"
  }
}

// Prisma schema for ObservAI database
// PostgreSQL database schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User accounts and authentication
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  role          String  @default("MANAGER")
  accountType   String  @default("TRIAL") // TRIAL | PAID
  trialExpiresAt DateTime?
  companyName   String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Notification settings
  telegramChatId        String?   // Telegram bot chat ID
  telegramNotifications Boolean   @default(false)
  emailNotifications    Boolean   @default(true)
  notifySeverity        String    @default("high") // min severity: low | medium | high | critical
  quietHoursEnabled     Boolean   @default(false)
  quietHoursStart       String?   // "22:00"
  quietHoursEnd         String?   // "08:00"
  dailySummaryEnabled   Boolean   @default(false)
  dailySummaryTime      String?   // "09:00"

  // Relations
  cameras       Camera[]
  zones         Zone[]
  sessions      Session[]
  passwordResets PasswordReset[]
  branches      Branch[]

  @@map("users")
}

// User session management
model Session {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Password reset tokens
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// Branch/Location management
model Branch {
  id        String   @id @default(uuid())
  name      String
  city      String
  latitude  Float
  longitude Float
  timezone  String   @default("Europe/Istanbul")
  userId    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cameras Camera[]

  @@map("branches")
}

// Camera/Video source configuration
model Camera {
  id          String       @id @default(uuid())
  name        String
  description String?
  sourceType  String
  sourceValue String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String
  branchId    String?

  // Configuration
  config      String? // JSON string

  // Relations
  user          User            @relation(fields: [createdBy], references: [id])
  branch        Branch?         @relation(fields: [branchId], references: [id])
  zones         Zone[]
  analyticsLogs AnalyticsLog[]

  @@map("cameras")
}

// Zone definitions (drawn on camera feed)
model Zone {
  id         String   @id @default(uuid())
  cameraId   String
  name       String
  type       String

  // Normalized coordinates [0-1]
  coordinates String    // JSON string

  // Visual properties
  color      String   @default("#3b82f6")

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String

  // Relations
  camera        Camera         @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [createdBy], references: [id])
  zoneInsights  ZoneInsight[]

  @@map("zones")
}

// Analytics data snapshots (time-series data)
model AnalyticsLog {
  id        String   @id @default(uuid())
  cameraId  String
  timestamp DateTime @default(now())

  // Metrics
  peopleIn     Int      @default(0)
  peopleOut    Int      @default(0)
  currentCount Int      @default(0)

  // Demographics
  demographics String?    // JSON string

  // Queue metrics
  queueCount      Int?
  avgWaitTime     Float?
  longestWaitTime Float?

  // Performance
  fps Float?

  // Heatmap data
  heatmap String?        // JSON string

  // Active people snapshot
  activePeople String?   // JSON string

  // Relations
  camera Camera @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@index([cameraId, timestamp])
  @@map("analytics_logs")
}

// Zone occupancy insights (alerts for long duration stays)
model ZoneInsight {
  id        String   @id @default(uuid())
  zoneId    String
  timestamp DateTime @default(now())

  // Person info
  personId  String   // track_xxx
  duration  Float    // seconds

  // Demographics (if available)
  gender    String?
  age       Int?

  // Message
  message   String

  // Relations
  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId, timestamp])
  @@map("zone_insights")
}

// AI-generated insights (real-time alerts, trends, recommendations)
model Insight {
  id        String   @id @default(uuid())
  cameraId  String
  zoneId    String?
  type      String   // 'occupancy_alert' | 'wait_time_alert' | 'crowd_surge' | 'trend' | 'recommendation' | 'demographic_trend'
  severity  String   @default("medium") // 'low' | 'medium' | 'high' | 'critical'
  title     String
  message   String
  context   String?  // JSON string with raw data context
  isRead    Boolean  @default(false)
  // Yan #44: YYYY-MM-DD UTC bucket so a 6h cron re-runs on the same day
  // upsert into the same row instead of duplicating it.
  dateKey   String?
  // Yan #57: soft-dismiss UX — list endpoint hides dismissed rows, but the
  // row stays for analytics/audit. Default filter: dismissedAt IS NULL.
  dismissedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@unique([cameraId, type, dateKey])
  @@index([cameraId, createdAt])
  @@index([type, severity])
  @@map("insights")
}

// Table occupancy events (status transitions for TABLE zones)
model TableEvent {
  id        String   @id @default(uuid())
  zoneId    String
  status    String   // "occupied" | "needs_cleaning" | "empty"
  startTime DateTime
  endTime   DateTime?
  occupants Int      @default(0)
  duration  Float?   // seconds
  cameraId  String
  createdAt DateTime @default(now())

  @@index([zoneId, startTime])
  @@index([cameraId, createdAt])
  @@map("table_events")
}

// Staff shift tracking for personnel optimization (legacy — hourly counters)
model StaffShift {
  id         String   @id @default(uuid())
  branchId   String
  date       DateTime
  hour       Int      // 0-23
  staffCount Int
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([branchId, date, hour])
  @@index([branchId, date])
  @@map("staff_shifts")
}

// Individual staff members (personnel records)
model Staff {
  id                      String   @id @default(uuid())
  userId                  String   // owner (restoran sahibi)
  branchId                String?
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  telegramChatId          String?
  // Single-use onboarding token. Generated when the staff row is created, used
  // by the Telegram deep link (t.me/<bot>?start=<token>) and cleared once the
  // webhook binds a chat_id. No long-lived secret; invalidates after first use.
  telegramOnboardingToken String?  @unique
  role                    String   @default("server") // server|chef|cashier|host|manager
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  assignments StaffAssignment[]

  @@index([userId, branchId])
  @@index([branchId, isActive])
  @@map("staff")
}

// Concrete shift assignments tied to specific staff
model StaffAssignment {
  id                  String    @id @default(uuid())
  staffId             String
  branchId            String
  date                DateTime  // Date only (no time)
  shiftStart          String    // "09:00"
  shiftEnd            String    // "17:00"
  role                String?
  status              String    @default("pending") // pending|accepted|declined|completed
  notifiedViaTelegram Boolean   @default(false)
  notifiedViaEmail    Boolean   @default(false)
  notifiedAt          DateTime?
  acceptToken         String?   @unique
  // Yan #59: track when the link was actually used + when it expires so the
  // accept/decline flow can return 410 Gone after TTL and stay idempotent on
  // repeat clicks instead of letting a leaked token toggle status forever.
  acceptedAt          DateTime?
  acceptTokenExpires  DateTime?
  notes               String?
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
  @@index([branchId, date])
  @@map("staff_assignments")
}

// Notification delivery audit log (ADIM 19).
// Every Telegram/email send goes here so the Staffing UI can prove real
// messages left the server — not just a mocked "sent" counter. Successes and
// failures both recorded; `error` carries the upstream reason when success=false.
model NotificationLog {
  id           String   @id @default(uuid())
  userId       String?  // owner of the action (restoran sahibi), null for system-triggered
  staffId      String?  // staff member the notification is about (if any)
  assignmentId String?  // StaffAssignment id when the log comes from a shift dispatch
  event        String   // "staff_shift" | "alert" | "test" | "onboarding"
  channel      String   // "telegram" | "email"
  target       String?  // chat_id or email address (redacted-safe is fine)
  success      Boolean
  messageId    String?  // provider-side id when available
  error        String?
  payload      String?  // JSON snapshot of the message contents (for replay/debug)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([staffId, createdAt])
  @@index([event, createdAt])
  @@map("notification_logs")
}

// Chat messages for AI chatbot conversation history (Stage 6).
// Enables the assistant to recall prior turns within the same conversation,
// so follow-up questions like "peki cinsiyet dağılımı?" work without re-stating context.
model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  userId         String?
  role           String   // "user" | "assistant"
  content        String
  model          String?  // e.g. "ollama/qwen3:14b" — diagnostic only
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@map("chat_messages")
}

// Historical analytics aggregates (for faster queries)
model AnalyticsSummary {
  id        String   @id @default(uuid())
  cameraId  String
  date      DateTime // Date only (no time)
  hour      Int?     // 0-23, null for daily summary

  // Aggregated metrics
  totalEntries  Int
  totalExits    Int
  peakOccupancy Int
  avgOccupancy  Float

  // Demographics summary
  demographics String? // JSON string

  // Queue stats
  avgQueueLength Float?
  avgWaitTime    Float?

  createdAt DateTime @default(now())

  @@unique([cameraId, date, hour])
  @@index([cameraId, date])
  @@map("analytics_summaries")
}
